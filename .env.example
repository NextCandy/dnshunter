# ===== 必填 =====
# 生成方式示例：openssl rand -hex 32
# 生产环境必须改成 32 字节以上随机值；不要提交真实值。
SESSION_SECRET=change-me-to-a-long-random-string-32chars-min
# 打开站点需要输入的共享密码，建议 16 位以上强密码；不要提交真实值。
SITE_PASSWORD=change-me-to-a-strong-site-password
# Cloudflare API Token（可选）。没有时留空，功能入口会显示未配置。
# 可留空，登录后在「设置」页 UI 填写保存（加密持久化到 data/secrets.json）
CLOUDFLARE_API_TOKEN=

# ===== NAS 部署 =====
# 容器时区，默认 Asia/Shanghai
TZ=Asia/Shanghai
# docker compose 宿主机映射端口。NAS 上避免使用常见冲突端口 3000，默认建议 8834。
HOST_PORT=8834
# NAS 内网 http 访问必须设为 false，否则解锁后 Secure Cookie 不会下发并会回到登录页。
# 如果后续通过 HTTPS 反向代理访问，可以改为 true。
COOKIE_SECURE=false

# ===== 注册商（可选，按需填写；未配置的入口会置灰或显示未配置）=====
# 也可以登录后在「设置」页 UI 填写，系统会加密保存到 data/secrets.json。
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=
DYNADOT_API_KEY=
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
WEST_USERNAME=
WEST_API_PASSWORD=
